SERVER_PORT=8002
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_127=http://127.0.0.1:5173

# 推荐使用这一组变量，和本机已有环境变量保持一致。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
MODEL_ID=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# 兼容 Spring AI 示例命名；如果已经配置上面的变量，这一组可以不配。
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_MODEL=gpt-4o-mini
SPRING_AI_OPENAI_TEMPERATURE=0.7

AI_MOCK_ENABLED=true
AI_DEFAULT_SYSTEM_PROMPT=你是一个中文友好的 Java 后端学习助手，回答要清晰、准确，并优先解释设计原因。

# 阶段 10.1：岗位情报联网搜索。仅在用户填写岗位、公司或 JD 时触发。
# 未配置 TAVILY_API_KEY 时自动降级为“简历 + 用户填写岗位信息”出题，不会伪造搜索结果。
JOB_INTELLIGENCE_SEARCH_ENABLED=true
JOB_INTELLIGENCE_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
JOB_INTELLIGENCE_MAX_RESULTS=5
JOB_INTELLIGENCE_TIMEOUT=8s

# 模拟面试流程策略。默认 8 道起步、12 道标准、最多 15 道，每个主问题最多追问 3 轮。
INTERVIEW_INITIAL_QUESTION_COUNT=8
INTERVIEW_STANDARD_QUESTION_COUNT=12
INTERVIEW_MAX_QUESTION_COUNT=15
INTERVIEW_MAX_FOLLOW_UP_COUNT=3

# 最终认证方案使用 Sa-Token，不再使用 JWT。
# 前端仍通过 Authorization: Bearer <token> 携带登录态，后端拦截器会兼容这种写法。
SA_TOKEN_TIMEOUT_SECONDS=86400
SA_TOKEN_ACTIVE_TIMEOUT_SECONDS=-1
SA_TOKEN_IS_CONCURRENT=true
SA_TOKEN_IS_SHARE=true

# 阶段 4：用户数据使用 MySQL，聊天会话和消息快照使用 MongoDB。
MYSQL_URL=jdbc:mysql://localhost:3306/my_ai_meeting?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=root
MYSQL_INIT_FAIL_TIMEOUT=1
SQL_INIT_MODE=never
MONGODB_URI=mongodb://localhost:27017/my_ai_meeting

# 阶段 8.5：AI 调用稳定性治理。默认使用本机 Docker Redis：docker run -d --name myai-redis -p 6379:6379 redis:7
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2s
AI_GUARD_ENABLED=true
AI_GUARD_REDIS_REQUIRED=false
AI_GUARD_NAMESPACE=meetingagent:ai
AI_GUARD_LOCK_TTL=30s
AI_GUARD_RESULT_TTL=10m
AI_GUARD_WAIT_TIMEOUT=6s
AI_GUARD_POLL_INTERVAL=100ms
AI_GUARD_CALL_TIMEOUT=25s
AI_GUARD_USER_LIMIT_PER_MINUTE=20
AI_GUARD_FALLBACK_ANSWER=AI 服务暂时不稳定，本次先给出降级回复：请稍后重试，或把问题拆得更具体后再次提交。

# pgvector 向量检索。默认关闭；开启前先启动 docker-compose.dev.yml 中的 myai-pgvector。
# RAG_VECTOR_REQUIRED=false 表示 pgvector 不可用时自动退回本地文本召回；设为 true 会让启动/检索失败显式暴露。
RAG_VECTOR_ENABLED=false
RAG_VECTOR_REQUIRED=false
PGVECTOR_JDBC_URL=jdbc:postgresql://localhost:5432/my_ai_meeting_vector
PGVECTOR_USERNAME=postgres
PGVECTOR_PASSWORD=1234
RAG_VECTOR_DIMENSION=1536
RAG_VECTOR_TABLE=knowledge_chunk_vector
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_EMBEDDING_MOCK_ENABLED=false

# 扫描版 PDF OCR。默认关闭；开启前需要本机安装 tesseract，并安装 chi_sim 与 eng 语言包。
RESUME_OCR_ENABLED=false
RESUME_OCR_COMMAND=tesseract
RESUME_OCR_LANGUAGE=chi_sim+eng
RESUME_OCR_DPI=220
RESUME_OCR_MAX_PAGES=5
RESUME_OCR_TIMEOUT=20s

# 真实媒体供应商。默认 local 是本地模式；openai 表示调用 OpenAI Compatible 音频接口。
# 当前不是讯飞专有协议，如果要写“讯飞”，需要后续新增讯飞 Provider。
MEDIA_ASR_PROVIDER=local
MEDIA_ASR_MODEL=whisper-1
MEDIA_ASR_LANGUAGE=zh
MEDIA_TTS_PROVIDER=local
MEDIA_TTS_MODEL=tts-1
MEDIA_TTS_VOICE=alloy
MEDIA_TTS_RESPONSE_FORMAT=wav
