SERVER_PORT=8002
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_127=http://127.0.0.1:5173

# 推荐使用这一组变量，和本机已有环境变量保持一致。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
MODEL_ID=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# 兼容 Spring AI 示例命名；如果已经配置上面的变量，这一组可以不配。
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://api.openai.com
SPRING_AI_OPENAI_MODEL=gpt-4o-mini
SPRING_AI_OPENAI_TEMPERATURE=0.7

AI_MOCK_ENABLED=true
AI_DEFAULT_SYSTEM_PROMPT=你是一个中文友好的 Java 后端学习助手，回答要清晰、准确，并优先解释设计原因。

JWT_SECRET=please-change-this-development-secret-32
JWT_EXPIRE_MINUTES=1440

# 阶段 4：用户数据使用 MySQL，聊天会话和消息快照使用 MongoDB。
MYSQL_URL=jdbc:mysql://localhost:3306/my_ai_meeting?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
MYSQL_USERNAME=root
MYSQL_PASSWORD=root
MYSQL_INIT_FAIL_TIMEOUT=1
SQL_INIT_MODE=never
MONGODB_URI=mongodb://localhost:27017/my_ai_meeting
